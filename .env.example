# Leave empty for the public demo. Set a strong random value for production MCP auth.
ARCHLENS_MCP_TOKEN=
# Requests per client IP per rolling minute. Defaults to 60.
ARCHLENS_MCP_RATE_LIMIT_PER_MINUTE=60
# D1-backed source report recording is disabled by default. Enable only in a
# deployment where the write endpoint is intentionally exposed.
ARCHLENS_SOURCE_INTAKE_WRITE_ENABLED=false
# Maximum persisted source-report JSON size. Defaults to 250000 bytes.
ARCHLENS_SOURCE_INTAKE_MAX_REPORT_BYTES=250000
