{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/qoderwork/xiaohongshu-studio/schemas/publish-history-row.schema.json",
  "title": "publish-history.jsonl row",
  "description": "发布复盘追加写入的每行 JSONL 记录 schema。v1.3.2+ 完整字段。",
  "type": "object",
  "required": ["date", "platform", "title", "topic_type", "verdict"],
  "properties": {
    "date": {"type": "string", "format": "date"},
    "platform": {
      "type": "string",
      "enum": ["xiaohongshu", "douyin_text", "wechat_oa", "zhihu", "jike", "twitter"]
    },
    "title": {"type": "string"},
    "topic_band": {
      "type": "string",
      "enum": ["拆书", "教程", "种草", "情绪"],
      "description": "4-way CTR 指导（v1.3.2+）"
    },
    "topic_type": {
      "type": "string",
      "enum": ["拆书", "教程", "种草", "情绪", "清单", "反常识"],
      "description": "6-way JSONL 字段"
    },
    "viral_structure": {"type": "string", "enum": ["痛点解决", "反常识", "干货清单", "情绪共鸣"]},
    "palette": {"type": "string", "enum": ["warm_knowledge", "fresh_lifestyle", "dark_hook", "literary_mood"]},
    "cover_has_image": {"type": "boolean"},
    "series": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "episode": {"type": "integer"}
      }
    },
    "persona_score": {"oneOf": [{"type": "number"}, {"type": "null"}]},
    "metrics": {
      "type": "object",
      "properties": {
        "impressions": {"type": "integer"},
        "reads": {"type": "integer"},
        "ctr": {"type": "number"},
        "likes": {"type": "integer"},
        "saves": {"type": "integer"},
        "comments": {"type": "integer"},
        "shares": {"type": "integer"},
        "interaction_rate": {"type": "number"},
        "save_like_ratio": {"type": "number"},
        "completion_rate": {"type": "number"}
      }
    },
    "verdict": {"type": "string", "enum": ["above_baseline", "at_baseline", "below_baseline"]},
    "winning_factors": {"type": "array", "items": {"type": "string"}},
    "losing_factors": {"type": "array", "items": {"type": "string"}},
    "next_action": {"type": "string"},
    "cross_platform_ref": {
      "type": "object",
      "description": "v1.3.2+ 对象形状：{ platform_id: ref_key }。同主题多平台数据用此字段互引。",
      "additionalProperties": {"type": "string"}
    }
  }
}
