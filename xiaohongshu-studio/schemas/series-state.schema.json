{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/qoderwork/xiaohongshu-studio/schemas/series-state.schema.json",
  "title": "series-state.json",
  "description": "系列批量模式进度追踪文件。v1.3.2 起 schema 化。",
  "type": "object",
  "required": ["schema_version", "series_id", "episodes"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\.3\\."},
    "series_id": {"type": "string"},
    "total_planned": {"type": "integer", "minimum": 1},
    "episodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vol", "status"],
        "properties": {
          "vol": {"type": "integer", "minimum": 1},
          "episode_id": {
            "type": "string",
            "description": "v1.3.3 起前缀必须用 project_id（不是 series_id）；旧版兼容（运行时回退 {project_id}-vol-{vol} 构造）"
          },
          "status": {"type": "string", "enum": ["pending", "in_progress", "done", "blocked", "skipped"]},
          "output_dir": {"type": "string"},
          "published_at": {"oneOf": [{"type": "string", "format": "date-time"}, {"type": "null"}]},
          "publish_history_keys": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
