{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/qoderwork/xiaohongshu-studio/schemas/persona-profile.schema.json",
  "title": "persona-profile.json",
  "description": "人设语料库产出文件 schema。v1.3.3 drift_alert 由 发布复盘 Step 4.7 自动写。",
  "type": "object",
  "required": ["schema_version", "owner", "dimensions"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\."},
    "owner": {"type": "string", "description": "作者 / 账号名"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "voice_summary": {"type": "string", "description": "1 句话总结本人语感"},

    "dimensions": {
      "type": "object",
      "required": [
        "catchphrases",
        "sentence_preference",
        "punctuation",
        "emoji_density",
        "title_hook_types",
        "paragraph_length",
        "forbidden_phrases",
        "signature_templates"
      ],
      "properties": {
        "catchphrases": {
          "type": "array",
          "items": {"type": "string"},
          "description": "高频出现但不是通用爆款的词"
        },
        "sentence_preference": {
          "type": "object",
          "properties": {
            "avg_length": {"type": "string", "enum": ["short", "medium", "long"]},
            "fav_structures": {"type": "array", "items": {"type": "string"}}
          }
        },
        "punctuation": {
          "type": "object",
          "properties": {
            "exclamation": {"type": "string", "enum": ["rare", "moderate", "frequent"]},
            "question": {"type": "string", "enum": ["rare", "moderate", "frequent"]},
            "ellipsis": {"type": "string", "enum": ["rare", "moderate", "frequent"]},
            "dash": {"type": "string", "enum": ["rare", "moderate", "frequent"]},
            "tilde": {"type": "string", "enum": ["never", "rare", "moderate"]}
          }
        },
        "emoji_density": {"type": "string", "enum": ["none", "low", "medium", "high"]},
        "title_hook_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "self_deprecating", "counterintuitive", "framework_naming",
              "data_promise", "authority_cite", "emotional_resonance",
              "pain_question", "result_commit"
            ]
          }
        },
        "paragraph_length": {"type": "string", "enum": ["1_line", "short", "medium", "long"]},
        "forbidden_phrases": {
          "type": "array",
          "items": {"type": "string"},
          "description": "硬约束：全文禁止出现的词"
        },
        "signature_templates": {
          "type": "array",
          "items": {"type": "string"},
          "description": "高频表达结构（'不是 A，是 B' 等）"
        }
      }
    },

    "sample_quotes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "do": {"type": "array", "items": {"type": "string"}},
    "dont": {"type": "array", "items": {"type": "string"}},

    "drift_alert": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "description": "v1.3.3 起由 发布复盘 Step 4.7 自动写。连续 3 (title, episode) 唯一对 persona_score < 3.5 触发。",
          "properties": {
            "triggered_at": {"type": "string", "format": "date-time"},
            "consecutive_low_scores": {"type": "integer", "minimum": 1},
            "recent_scores": {"type": "array", "items": {"type": "number"}},
            "deduplicated_by": {"type": "string", "default": "(title, series.episode)"},
            "suggestion": {"type": "string"}
          }
        }
      ]
    }
  }
}
