{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/qoderwork/xiaohongshu-studio/schemas/schedule.schema.json",
  "title": "schedule.json",
  "description": "6 平台错峰时间表 canonical 来源。v1.3.3 起。",
  "type": "object",
  "required": ["schema_version", "platforms"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\.3\\."},
    "description": {"type": "string"},
    "updated_at": {"type": "string", "format": "date-time"},
    "platforms": {
      "type": "object",
      "required": ["xiaohongshu", "douyin_text", "wechat_oa", "zhihu", "jike", "twitter"],
      "additionalProperties": false,
      "properties": {
        "xiaohongshu":  {"$ref": "#/definitions/platformEntry"},
        "douyin_text":  {"$ref": "#/definitions/platformEntry"},
        "wechat_oa":    {"$ref": "#/definitions/platformEntry"},
        "zhihu":        {"$ref": "#/definitions/platformEntry"},
        "jike":         {"$ref": "#/definitions/platformEntry"},
        "twitter":      {"$ref": "#/definitions/platformEntry"}
      }
    },
    "golden_slots": {
      "type": "object",
      "additionalProperties": {"type": "array", "items": {"type": "string"}}
    },
    "avoid_slots": {"type": "array", "items": {"type": "string"}},
    "series_cadence": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  },
  "definitions": {
    "platformEntry": {
      "type": "object",
      "required": ["display_name", "time", "offset_hours_from_xiaohongshu", "image_aspect", "tag_count", "primary"],
      "properties": {
        "display_name": {"type": "string"},
        "time": {"type": "string"},
        "offset_hours_from_xiaohongshu": {"type": "integer"},
        "image_aspect": {"type": "string"},
        "tag_count": {"type": "string"},
        "primary": {"type": "boolean"}
      }
    }
  }
}
